{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Athanor",
  "theme": "mint",
  "colors": {
    "primary": "#000000",
    "light": "#555555",
    "dark": "#ffffff"
  },
  "favicon": "images/favicon.png",
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "topbarLinks": [
    {
      "name": "GitHub",
      "url": "https://github.com/alexisbouchez/athanor"
    }
  ],
  "topbarCtaButton": {
    "type": "github",
    "url": "https://github.com/alexisbouchez/athanor"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "getting-started/installation",
          "getting-started/quickstart",
          "getting-started/writing-workflows"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/github-app",
          "guides/workflow-features",
          "guides/job-dependencies",
          "guides/step-outputs",
          "guides/conditions-and-errors"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/cli",
          "reference/architecture",
          "reference/supported-features"
        ]
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/alexisbouchez/athanor"
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true
  }
}
